# ============================================================
# autonomous-blogger — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# All of these map to GitHub Actions Secrets for CI/CD.
# ============================================================

# ── Gemini AI ────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyDElvYdtT6IJ8esr9I5zwKq73H0tIyKSFo
GEMINI_PRIMARY_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODEL=gemini-1.5-flash
GEMINI_DAILY_QUOTA=1500          # Free tier RPD limit (requests per day)
GEMINI_RPM_LIMIT=15              # Free tier requests per minute

# ── Blogger API ───────────────────────────────────────────────
BLOGGER_BLOG_ID=1475086792050038552
# Path to downloaded OAuth2 client_secrets.json (local dev only)
BLOGGER_CLIENT_SECRETS_PATH=config/client_secrets.json
# For GitHub Actions: paste the full JSON content as a secret
BLOGGER_OAUTH_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"...","token_uri":"..."}}
# Blogger refresh token (obtained once via oauth_setup.py)
BLOGGER_REFRESH_TOKEN=1//0gICH2cIr5vSbCgYIARAAGBASNwF-L9Irm2QGJauwTZCEu7bYHwSM3AWy7Le5lhn2i_ZbFLIrAIMDxisU0IlFzeBbRDcgoqDbYJA

# ── YouTube Data API ─────────────────────────────────────────
YOUTUBE_API_KEY=AIzaSyC3uGCH0jjrMQaWuLWS8qX7lEiF3szVCx0
YOUTUBE_DAILY_QUOTA=10000        # Free tier units/day

# ── Firebase Realtime Database (Spark free plan) ─────────────
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
# Service account JSON — paste full content as GitHub Secret
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Disqus (optional — for comment count display) ────────────
DISQUS_SHORTNAME=your_disqus_shortname
DISQUS_PUBLIC_KEY=your_disqus_public_key      # For comment count API
DISQUS_SECRET_KEY=your_disqus_secret_key

# ── GitHub (for log persistence) ─────────────────────────────
GITHUB_TOKEN=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          # Personal Access Token (repo scope)
GITHUB_REPO_OWNER=mohimaninfo
GITHUB_REPO_NAME=The-Omniview-Auto-Blog

# ── General pipeline settings ────────────────────────────────
POSTS_PER_DAY=3                  # How many posts to publish daily
TIMEZONE=UTC                     # Cron timezone reference
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
DRY_RUN=false                    # Set true to skip actual publishing
